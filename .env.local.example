# ─────────────────────────────────────────────
# Bright Data
# https://brightdata.com → Proxies & Scraping Infrastructure
# ─────────────────────────────────────────────
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker_1
BRIGHTDATA_SERP_ZONE=serp_1

# ─────────────────────────────────────────────
# AI Provider — choose OpenRouter or OpenAI
# ─────────────────────────────────────────────

# OpenRouter (recommended)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-3-flash-preview

# OpenAI (alternative — set AI_PROVIDER=openai)
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# Convex — Realtime database + event log
# https://convex.dev → create a free project
# Run `npx convex dev` to get these values
# ─────────────────────────────────────────────
CONVEX_DEPLOYMENT=prod:your-deployment-slug
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# ─────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────

# Allow clients to pass their own API key in the request body.
# Useful for local demos — do NOT enable in production.
# ALLOW_CLIENT_API_KEYS=true
